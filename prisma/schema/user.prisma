model Users {
    id            String          @id @default(uuid())
    name          String
    email         String          @unique
    password      String
    role          Role
    isBanned      Boolean         @default(false)
    createdAt     DateTime        @default(now())
    updatedAt     DateTime        @updatedAt
    Landlord      Property[]
    rentalRequest RentalRequest[]
    payment       Payment[]
    reviews       Review[]
}
